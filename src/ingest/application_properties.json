[
  {
    "PropertyGroupId": "kinesis.analytics.flink.run.options",
    "PropertyMap": {
      "jarfile": "lib/pyflink-dependencies.jar",
      "pyFiles": "my_deps.zip,utils.zip,resources.zip",
      "python": "main.py"
    }
  },
  {
    "PropertyGroupId": "IngestConfig",
    "PropertyMap": {
      "s3_input": "s3a://icicle-fs-small/fs-small-10k",
